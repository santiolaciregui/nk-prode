rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        ("email" in request.auth.token && request.auth.token.email == "santi.olaciregui13@gmail.com")
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'status', 'role']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.status in ['pending', 'active', 'inactive'] &&
             data.role in ['admin', 'user'];
    }

    function isValidPrediction(data) {
      return data.keys().hasAll(['userId', 'matchId', 'homeScore', 'awayScore']) &&
             data.userId == request.auth.uid &&
             data.matchId is string && data.matchId.size() <= 200 &&
             data.homeScore is int && data.homeScore >= 0 && data.homeScore <= 20 &&
             data.awayScore is int && data.awayScore >= 0 && data.awayScore <= 20;
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['id', 'homeTeam', 'awayTeam', 'date', 'round']) &&
             data.homeTeam is string && data.homeTeam.size() <= 50 &&
             data.awayTeam is string && data.awayTeam.size() <= 50;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && userId == request.auth.uid && 
                       isValidUser(incoming()) && 
                       incoming().uid == userId &&
                       incoming().status == 'pending' &&
                       incoming().role == 'user';
      allow update: if (isOwner(userId) && isValidUser(incoming()) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['transferReceipt', 'displayName'])) ||
                       (isAdmin() && isValidUser(incoming()) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'role', 'points', 'exactCount', 'winnerCount']));
    }

    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /predictions/{predId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || request.auth.uid != null);
      allow create: if isSignedIn() &&
                       isValidPrediction(incoming()) &&
                       incoming().userId == request.auth.uid;
      allow update: if (isSignedIn() && isOwner(existing().userId) && isValidPrediction(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['homeScore', 'awayScore', 'updatedAt'])) ||
                       (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['pointsEarned']));
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }
  }
}
